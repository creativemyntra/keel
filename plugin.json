{
  "name": "keel",
  "displayName": "Keel AI-SDLC Framework",
  "version": "2.1.0",
  "description": "Complete AI-SDLC pipeline: Brainstorm → Requirements → Design → Code → Test → Security → Deploy",
  "author": "Amar Singh",
  "license": "MIT",
  "repository": "https://github.com/amarsingh/keel",
  "homepage": "https://github.com/amarsingh/keel#readme",
  "bugs": "https://github.com/amarsingh/keel/issues",
  "keywords": [
    "ai-sdlc",
    "code-generation",
    "testing",
    "security",
    "deployment",
    "automated-development",
    "devops",
    "cicd",
    "ai-powered",
    "claude-ai"
  ],
  "category": "DevOps",
  "tags": [
    "ai-powered",
    "automation",
    "development",
    "testing",
    "security"
  ],

  "keel": {
    "minVersion": "2.0.0",
    "maxVersion": "*",
    "interface": "1.0",
    "type": "framework"
  },

  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },

  "installation": {
    "methods": [
      {
        "name": "claude-code-skill",
        "displayName": "Claude Code Skill",
        "setupTime": "2 min",
        "complexity": "easy",
        "description": "Install as Claude Code skill for individual developers",
        "command": "cd ~/.claude/skills && git clone https://github.com/amarsingh/keel.git"
      },
      {
        "name": "npm-global",
        "displayName": "npm Global Package",
        "setupTime": "1 min",
        "complexity": "easy",
        "description": "Install as global npm package",
        "command": "npm install -g @amarsingh/keel"
      },
      {
        "name": "docker",
        "displayName": "Docker Container",
        "setupTime": "3 min",
        "complexity": "medium",
        "description": "Run in containerized environment",
        "command": "docker pull amarsingh/keel:latest"
      },
      {
        "name": "github-action",
        "displayName": "GitHub Action",
        "setupTime": "1 min",
        "complexity": "easy",
        "description": "Use in GitHub workflows",
        "command": "uses: amarsingh/keel@v2.1.0"
      }
    ]
  },

  "integrations": {
    "required": [],
    "optional": [
      {
        "name": "jira",
        "displayName": "Jira",
        "description": "Track development work in Jira",
        "website": "https://www.atlassian.com/software/jira",
        "mcp": "atlassian",
        "config": {
          "url": "https://your-domain.atlassian.net",
          "username": "email@example.com",
          "apiToken": "required"
        }
      },
      {
        "name": "github",
        "displayName": "GitHub",
        "description": "Integrate with GitHub repositories",
        "website": "https://github.com",
        "mcp": "github",
        "config": {
          "personalAccessToken": "required",
          "repository": "owner/repo"
        }
      },
      {
        "name": "playwright",
        "displayName": "Playwright",
        "description": "E2E testing and browser automation",
        "website": "https://playwright.dev",
        "mcp": "playwright",
        "config": {
          "headless": true,
          "browsers": ["chromium", "firefox", "webkit"]
        }
      },
      {
        "name": "slack",
        "displayName": "Slack",
        "description": "Send notifications to Slack",
        "website": "https://slack.com",
        "mcp": "slack",
        "config": {
          "webhookUrl": "required",
          "channel": "#development"
        }
      },
      {
        "name": "datadog",
        "displayName": "Datadog",
        "description": "Monitor and observe deployments",
        "website": "https://www.datadoghq.com",
        "mcp": "datadog",
        "config": {
          "apiKey": "required",
          "appKey": "required"
        }
      }
    ]
  },

  "features": {
    "core": [
      "8 Autonomous Agents",
      "5 Development Phases",
      "TDD Workflow (Red→Green→Refactor)",
      "87% Test Coverage Baseline",
      "Enterprise Security",
      "Real-time Dashboard",
      "Audit Trail",
      "Cost Tracking"
    ],
    "advanced": [
      "CodeGraph (Dependency Analysis)",
      "Hallucination Detector",
      "Error Recovery",
      "Checkpoint/Rollback",
      "Feedback Loop Automation",
      "Custom Evaluators",
      "A/B Testing Framework",
      "Multi-phase Orchestration"
    ]
  },

  "phases": [
    {
      "id": "init",
      "name": "Initialize",
      "description": "Project scaffolding and governance setup"
    },
    {
      "id": "brainstorm",
      "name": "Brainstorm",
      "description": "Ideation and concept generation"
    },
    {
      "id": "req",
      "name": "Requirements",
      "description": "Detailed requirements and acceptance criteria"
    },
    {
      "id": "design",
      "name": "Design",
      "description": "Architecture and system design"
    },
    {
      "id": "dev",
      "name": "Development",
      "description": "Code generation with TDD"
    },
    {
      "id": "test",
      "name": "Testing",
      "description": "Comprehensive test suite"
    },
    {
      "id": "sec",
      "name": "Security",
      "description": "Security scanning and compliance"
    },
    {
      "id": "deploy",
      "name": "Deploy",
      "description": "Production deployment"
    }
  ],

  "stacks": [
    {
      "name": "cakephp",
      "displayName": "CakePHP 4.4",
      "version": "4.4",
      "php": "8.1+",
      "database": "mysql",
      "description": "PHP framework for enterprise applications"
    },
    {
      "name": "laravel",
      "displayName": "Laravel 10",
      "version": "10",
      "php": "8.2+",
      "database": "postgresql",
      "description": "Modern PHP framework"
    },
    {
      "name": "django",
      "displayName": "Django 4.2",
      "version": "4.2",
      "python": "3.9+",
      "database": "postgresql",
      "description": "Python web framework"
    },
    {
      "name": "rails",
      "displayName": "Ruby on Rails 7",
      "version": "7",
      "ruby": "3.0+",
      "database": "postgresql",
      "description": "Ruby web framework"
    }
  ],

  "qualityGates": [
    {
      "phase": "req",
      "gate": "Requirements Complete",
      "criteria": ["All MUST requirements documented", "Acceptance criteria in BDD format"]
    },
    {
      "phase": "design",
      "gate": "Design Approved",
      "criteria": ["API specification complete", "Database schema finalized"]
    },
    {
      "phase": "dev",
      "gate": "Code Ready",
      "criteria": ["All code generated", "PSR-12 lint passing", "PHPStan L5 passing"]
    },
    {
      "phase": "test",
      "gate": "Tests Passing",
      "criteria": ["≥85% coverage", "All tests green", "Performance targets met"]
    },
    {
      "phase": "sec",
      "gate": "Security Cleared",
      "criteria": ["0 HIGH findings", "Dependencies clean", "OWASP 8/10"]
    },
    {
      "phase": "deploy",
      "gate": "Ready for Production",
      "criteria": ["Runbook complete", "Monitoring configured", "Rollback plan ready"]
    }
  ],

  "github": {
    "marketplace": {
      "category": "DevOps",
      "color": "blue",
      "icon": "zap",
      "verified": true
    },
    "releases": {
      "autoPublish": true,
      "prerelease": false
    }
  },

  "npm": {
    "package": "@amarsingh/keel",
    "registry": "npmjs",
    "scope": "@amarsingh",
    "keywords": [
      "ai-sdlc",
      "code-generation",
      "automation",
      "devops"
    ]
  },

  "docker": {
    "image": "amarsingh/keel",
    "registry": "docker.io",
    "tags": ["latest", "v2.1.0", "stable"]
  },

  "license": {
    "type": "MIT",
    "url": "https://github.com/amarsingh/keel/blob/main/LICENSE",
    "author": "Amar Singh",
    "commercial": true,
    "modification": true,
    "distribution": true
  }
}
