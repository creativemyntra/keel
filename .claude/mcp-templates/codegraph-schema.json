{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodeGraph Schema",
  "description": "Knowledge graph representing codebase structure, dependencies, and metrics",
  "type": "object",
  "required": ["version", "generated", "nodes", "edges", "metrics"],
  "properties": {
    "version": {
      "type": "string",
      "description": "CodeGraph schema version",
      "default": "1.0.0"
    },
    "generated": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when CodeGraph was generated"
    },
    "project_name": {
      "type": "string",
      "description": "Project name"
    },
    "stack": {
      "type": "string",
      "enum": ["cakephp", "laravel", "django", "rails", "nodejs", "java"],
      "description": "Technology stack"
    },
    "nodes": {
      "type": "object",
      "description": "All code entities (files, classes, functions)",
      "additionalProperties": {
        "oneOf": [
          { "$ref": "#/definitions/FileNode" },
          { "$ref": "#/definitions/ClassNode" },
          { "$ref": "#/definitions/FunctionNode" },
          { "$ref": "#/definitions/InterfaceNode" }
        ]
      }
    },
    "edges": {
      "type": "object",
      "description": "Relationships between nodes",
      "additionalProperties": {
        "$ref": "#/definitions/Edge"
      }
    },
    "metrics": {
      "$ref": "#/definitions/GlobalMetrics"
    },
    "architecture_rules": {
      "type": "array",
      "description": "Defined architecture constraints",
      "items": { "$ref": "#/definitions/ArchitectureRule" }
    },
    "violations": {
      "type": "array",
      "description": "Architecture rule violations",
      "items": { "$ref": "#/definitions/Violation" }
    }
  },
  "definitions": {
    "FileNode": {
      "type": "object",
      "properties": {
        "type": { "const": "file" },
        "path": { "type": "string" },
        "loc": { "type": "integer", "description": "Lines of code" },
        "complexity": { "type": "number" },
        "coverage": { "type": "number", "minimum": 0, "maximum": 100 },
        "classes": { "type": "array", "items": { "type": "string" } },
        "functions": { "type": "array", "items": { "type": "string" } },
        "imports": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["php", "python", "javascript", "java", "go", "rust"] }
      },
      "required": ["type", "path"]
    },
    "ClassNode": {
      "type": "object",
      "properties": {
        "type": { "const": "class" },
        "name": { "type": "string" },
        "file": { "type": "string" },
        "extends": { "type": "string" },
        "implements": { "type": "array", "items": { "type": "string" } },
        "methods": { "type": "array", "items": { "type": "string" } },
        "properties": { "type": "array", "items": { "type": "string" } },
        "complexity": { "type": "number" },
        "coverage": { "type": "number" },
        "dependencies": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "name", "file"]
    },
    "FunctionNode": {
      "type": "object",
      "properties": {
        "type": { "const": "function" },
        "name": { "type": "string" },
        "class": { "type": "string", "description": "Class if method, null if standalone function" },
        "file": { "type": "string" },
        "signature": { "type": "string" },
        "return_type": { "type": "string" },
        "parameters": { "type": "array", "items": { "type": "object" } },
        "cyclomatic_complexity": { "type": "integer" },
        "coverage": { "type": "number" },
        "calls": { "type": "array", "items": { "type": "string" } },
        "called_by": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "name", "file"]
    },
    "InterfaceNode": {
      "type": "object",
      "properties": {
        "type": { "const": "interface" },
        "name": { "type": "string" },
        "file": { "type": "string" },
        "methods": { "type": "array", "items": { "type": "string" } },
        "implementations": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["type", "name", "file"]
    },
    "Edge": {
      "type": "object",
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["depends_on", "calls", "extends", "implements", "contains", "references"]
        },
        "weight": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Importance of this dependency"
        },
        "circular": { "type": "boolean" },
        "external": { "type": "boolean", "description": "External library dependency" }
      },
      "required": ["from", "to", "type"]
    },
    "GlobalMetrics": {
      "type": "object",
      "properties": {
        "total_files": { "type": "integer" },
        "total_classes": { "type": "integer" },
        "total_functions": { "type": "integer" },
        "total_lines_of_code": { "type": "integer" },
        "avg_complexity": { "type": "number" },
        "avg_coverage": { "type": "number" },
        "circular_dependencies": { "type": "integer" },
        "architecture_violations": { "type": "integer" },
        "test_coverage_total": { "type": "number" }
      }
    },
    "ArchitectureRule": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "pattern": { "type": "string" },
        "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
        "enforce": { "type": "boolean" }
      },
      "required": ["name", "pattern", "severity"]
    },
    "Violation": {
      "type": "object",
      "properties": {
        "rule": { "type": "string" },
        "message": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "severity": { "type": "string" },
        "suggestion": { "type": "string" }
      },
      "required": ["rule", "message", "severity"]
    }
  }
}
