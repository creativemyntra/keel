{
  "version": "1.0.0",
  "name": "Keel AI-SDLC Framework v3.0.2",
  "description": "Enterprise-grade AI-driven SDLC with 13 autonomous agents",
  "author": "Amar Singh",
  "license": "MIT",

  "agents": {
    "directory": ".claude/agents",
    "auto_discovery": true
  },

  "mcp_servers": {
    "auto_start": true,
    "servers": [
      {
        "name": "jira-mcp",
        "type": "atlassian",
        "enabled": false,
        "config": {
          "config_file": "~/.keel/config/jira.yml",
          "token_file": "~/.keel/secrets/jira.token",
          "auto_sync_issues": true
        }
      },
      {
        "name": "github-mcp",
        "type": "github",
        "enabled": false,
        "config": {
          "config_file": "~/.keel/config/github.yml",
          "token_file": "~/.keel/secrets/github.token",
          "auto_create_releases": true
        }
      },
      {
        "name": "slack-mcp",
        "type": "slack",
        "enabled": false,
        "config": {
          "config_file": "~/.keel/config/slack.yml",
          "webhook_file": "~/.keel/secrets/slack.webhook"
        }
      },
      {
        "name": "playwright-mcp",
        "type": "playwright",
        "enabled": false,
        "config": {
          "config_file": "~/.keel/config/playwright.yml",
          "headless": true,
          "timeout": 30000
        }
      }
    ]
  },

  "environment": {
    "KEEL_VERSION": "3.0.2",
    "KEEL_HOME": "~/.keel",
    "KEEL_CONFIG_DIR": "~/.keel/config",
    "KEEL_SECRETS_DIR": "~/.keel/secrets",
    "KEEL_ENV": "production"
  },

  "compliance": {
    "standards": ["CJIS", "SOC2_TYPE_II", "HIPAA", "GDPR", "PCI_DSS", "SOX"],
    "audit_enabled": true,
    "encryption": {
      "enabled": true,
      "algorithm": "AES-256"
    }
  },

  "security": {
    "secrets_encryption": true,
    "rbac_enabled": true,
    "audit_all_actions": true
  },

  "telemetry": {
    "enabled": false,
    "track_errors": true,
    "data_collection": "minimal"
  }
}
