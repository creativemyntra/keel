{
  "hooks": {
    "SessionStart": [
      { "matcher": "startup", "hooks": [
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-init.cjs\"" },
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-watch.cjs\" --stale-check" }
      ]}
    ],
    "UserPromptSubmit": [
      { "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-classify-gate.cjs\" --stage=prompt" }] }
    ],
    "PreToolUse": [
      { "matcher": "Task|Write|Edit|Bash", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-classify-gate.cjs\" --stage=pre" }] },
      { "matcher": "mcp__.*__(createJiraIssue|editJiraIssue|addCommentToJiraIssue|transitionJiraIssue|addWorklogToJiraIssue|createIssueLink)", "hooks": [
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-jira-write.cjs\"" },
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/guard-approve.cjs\"" }
      ]}
    ],
    "PostToolUse": [
      { "matcher": "Bash", "hooks": [
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-watch.cjs\" --post-bash" },
        { "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-classify-gate.cjs\" --stage=post" }
      ]},
      { "matcher": "Read|Grep|mcp__.*", "hooks": [{ "type": "command", "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/keel-classify-gate.cjs\" --stage=post" }] }
    ]
  }
}
