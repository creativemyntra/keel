{
  "name": "@amarsingh/keel",
  "version": "3.16.3",
  "description": "Keel AI-SDLC Framework - Complete AI-powered software development lifecycle automation",
  "type": "module",
  "main": "bin/keel.js",
  "bin": {
    "keel": "./bin/keel.js"
  },
  "scripts": {
    "start": "node ./bin/keel.js",
    "test": "npm run test:engine && npm run test:phase-drift",
    "test:engine": "node scripts/test-keel-state.cjs",
    "test:phase-drift": "node scripts/test-phase-drift.cjs",
    "test:legacy": "npm run test:unit && npm run test:integration",
    "test:unit": "jest tests/unit --coverage",
    "test:integration": "jest tests/integration",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "ai-sdlc",
    "code-generation",
    "automation",
    "testing",
    "security",
    "development",
    "tdd",
    "devops",
    "agents",
    "ai-powered",
    "claude",
    "plugin"
  ],
  "author": "Amar Singh",
  "license": "MIT",
  "homepage": "https://github.com/creativemyntra/keel",
  "repository": {
    "type": "git",
    "url": "https://github.com/creativemyntra/keel.git"
  },
  "bugs": {
    "url": "https://github.com/creativemyntra/keel/issues"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.0.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "inquirer": "^8.2.5",
    "ora": "^7.0.1",
    "path-exists": "^5.0.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@playwright/test": "^1.61.1",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3"
  },
  "files": [
    "bin/",
    ".claude-plugin/",
    "commands/",
    "agents/",
    "skills/",
    "hooks/",
    "scripts/",
    "config/",
    "stack-profiles/",
    ".mcp.json",
    "agent-output-schema.json",
    "setup-integrations.sh",
    "action.yml",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
