# Keel AI-SDLC Framework — Environment Variables
# Copy to .env and fill in your API tokens
# NEVER commit .env to git (added to .gitignore)

# ============================================
# TIER 1: REQUIRED (Phases 1-5)
# ============================================

# GitHub — Personal Access Token
# Create: https://github.com/settings/tokens
# Scopes: repo, workflow, read:org
GITHUB_TOKEN=ghp_

# Jira — API Token (same as Confluence)
# Create: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
JIRA_INSTANCE=https://company.atlassian.net

# SonarQube — API Token
# Create: [instance]/account/security/generate-tokens
SONARQUBE_TOKEN=squ_
SONARQUBE_INSTANCE=https://sonarqube.example.com

# Playwright — Test Environment
# Base URL for E2E tests
PLAYWRIGHT_BASE_URL=https://uat-app.example.com
PLAYWRIGHT_HEADLESS=true

# ============================================
# TIER 2: ENHANCED (Optional)
# ============================================

# Slack — Bot Token
# Create: https://api.slack.com/apps
# Scopes: chat:write, files:write, reactions:write, channels:read
SLACK_BOT_TOKEN=xoxb_

# Confluence — API Token (uses JIRA_API_TOKEN)
# Instance: https://company.atlassian.net/wiki
CONFLUENCE_API_TOKEN=${JIRA_API_TOKEN}
CONFLUENCE_INSTANCE=https://company.atlassian.net/wiki

# Linear — API Key (alternative to Jira)
# Create: https://linear.app/settings/account/api
LINEAR_API_KEY=lin_

# Datadog — API Keys
# Create: https://app.datadoghq.com/account/settings
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ============================================
# TIER 3: ADVANCED (Domain-Specific)
# ============================================

# PagerDuty — API Token
# Create: https://pagerduty.com/api_keys
PAGERDUTY_API_TOKEN=

# Stripe — API Keys (for payment features)
# Create: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# AWS — Credentials (for infrastructure)
# Create: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Notion — API Key (for wiki)
# Create: https://www.notion.so/my-integrations
NOTION_API_KEY=

# ============================================
# FRAMEWORK CONFIGURATION
# ============================================

# Node Environment
NODE_ENV=development  # development, staging, production

# Stack Configuration
STACK=cakephp        # cakephp, laravel, django, rails

# Project Settings
PROJECT_NAME=keel
PROJECT_KEY=KEEL
PROJECT_NAMESPACE=com.example

# ============================================
# SECURITY & COMPLIANCE
# ============================================

# PCI Compliance Level (for payment processing)
PCI_LEVEL=1          # 1, 2, 3, or 4

# GDPR Compliance
GDPR_ENABLED=true
GDPR_RETENTION_DAYS=90

# Log Sensitive Data
LOG_SENSITIVE_DATA=false  # Set to false in production

# ============================================
# MONITORING & OBSERVABILITY
# ============================================

# Log Level
LOG_LEVEL=info       # debug, info, warn, error

# MCP Audit Logging
MCP_AUDIT_LOG=true
MCP_AUDIT_LOG_FILE=logs/mcp-audit.log

# Performance Monitoring
PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_FILE=logs/performance.log

# ============================================
# DEVELOPMENT & TESTING
# ============================================

# Development Flags
DEBUG=false
VERBOSE=false
DRY_RUN=false

# Test Configuration
TEST_DATABASE=keel_test
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPass123!

# ============================================
# OPTIONAL: Sensitive Overrides
# ============================================

# Database (if using local database for testing)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=keel

# Email (for testing)
MAIL_FROM=noreply@example.com
MAIL_HOST=smtp.example.com
MAIL_PORT=587

# ============================================
# NOTES
# ============================================

# 1. Copy this file to .env
#    cp .env.example .env

# 2. Fill in only the TIER 1 tokens first
#    (GitHub, Jira, SonarQube, Playwright)

# 3. Test connections:
#    /keel test-mcp --all

# 4. Add TIER 2 tokens as needed:
#    /keel setup-mcp --add=slack,confluence

# 5. NEVER commit .env to git
#    It's in .gitignore by default

# 6. For CI/CD, use environment secrets instead:
#    GitHub Actions: Settings → Secrets → Actions
#    GitLab CI: Settings → CI/CD → Variables
#    Jenkins: Manage Jenkins → Credentials

# Questions? See .claude/MCP-QUICK-START.md

