{
  "_comment": "NCIC_ID/LEID/HART_CASE_ID/HART_SUBJECT_ID are placeholders — replace with real formats from Forseti before relying on them. Both severities hard-block (ticket scenario 7: block over convenience).",
  "patterns": [
    { "category": "SSN", "pattern": "\\b\\d{3}-\\d{2}-\\d{4}\\b", "flags": "g", "severity": "hard" },
    { "category": "PHONE", "pattern": "\\b(\\+?1[-.\\s]?)?\\(?\\d{3}\\)?[-.\\s]?\\d{3}[-.\\s]?\\d{4}\\b", "flags": "g", "severity": "soft" },
    { "category": "EMAIL", "pattern": "\\b[\\w.+-]+@[\\w-]+\\.[\\w.-]+\\b", "flags": "gi", "severity": "soft" },
    { "category": "DOB", "pattern": "\\b(dob|date of birth|born)\\b[^\\n]{0,20}\\b\\d{1,2}[/-]\\d{1,2}[/-]\\d{2,4}\\b", "flags": "gi", "severity": "hard" },
    { "category": "NAME_NARRATIVE", "pattern": "\\b[A-Z][a-z]+ [A-Z][a-z]+ (was arrested|was booked|was detained|was charged)\\b", "flags": "g", "severity": "hard" },
    { "category": "ADDRESS", "pattern": "\\b\\d{1,5} [A-Za-z0-9. ]+ (St|Street|Ave|Avenue|Rd|Road|Blvd|Boulevard|Ln|Lane|Dr|Drive)\\b", "flags": "gi", "severity": "soft" },
    { "category": "NCIC_ID", "pattern": "\\bTODO-NCIC-FORMAT-PLACEHOLDER\\b", "flags": "g", "severity": "hard" },
    { "category": "LEID", "pattern": "\\bTODO-LEID-FORMAT-PLACEHOLDER\\b", "flags": "g", "severity": "hard" },
    { "category": "HART_CASE_ID", "pattern": "\\bTODO-HART-CASE-ID-FORMAT-PLACEHOLDER\\b", "flags": "g", "severity": "hard" },
    { "category": "HART_SUBJECT_ID", "pattern": "\\bTODO-HART-SUBJECT-ID-FORMAT-PLACEHOLDER\\b", "flags": "g", "severity": "hard" }
  ]
}
